#: data/gsettings/org.gnome.shotwell-extras.gschema.xml:6 data/gsettings/org.gnome.shotwell.gschema.xml:438
msgid "OAuth Access Phase Token"
msgstr "OAuth қол жеткізу кезеңінің токені"

#: data/gsettings/org.gnome.shotwell-extras.gschema.xml:7
msgid "The authorization token for the currently logged in Tumblr user, if any"
msgstr "Егер болса, қазіргі жүйеге кірген Tumblr пайдаланушысы үшін авторизация токені"

#: data/gsettings/org.gnome.shotwell-extras.gschema.xml:12 data/gsettings/org.gnome.shotwell.gschema.xml:444
msgid "OAuth Access Phase Token Secret"
msgstr "OAuth қол жеткізу кезеңінің токен құпиясы"

#: data/gsettings/org.gnome.shotwell-extras.gschema.xml:13
msgid "The cryptographic secret used to sign requests against the authorization token for the currently logged in Tumblr user, if any"
msgstr "Егер болса, қазіргі жүйеге кірген Tumblr пайдаланушысының авторизация токеніне сұранымдарға қол қою үшін қолданылатын криптографиялық құпия"

#: data/gsettings/org.gnome.shotwell-extras.gschema.xml:18 data/gsettings/org.gnome.shotwell.gschema.xml:450 data/gsettings/org.gnome.shotwell.gschema.xml:508 data/gsettings/org.gnome.shotwell.gschema.xml:570
msgid "username"
msgstr "пайдаланушы аты"

#: data/gsettings/org.gnome.shotwell-extras.gschema.xml:19 data/gsettings/org.gnome.shotwell.gschema.xml:451
msgid "The user name of the currently logged in Flickr user, if any"
msgstr "Егер болса, қазіргі жүйеге кірген Flickr пайдаланушысының аты"

#: data/gsettings/org.gnome.shotwell-extras.gschema.xml:24 data/gsettings/org.gnome.shotwell.gschema.xml:482
msgid "default size"
msgstr "үнсіз келісім өлшемі"

#: data/gsettings/org.gnome.shotwell-extras.gschema.xml:25
msgid "A numeric code representing the default size for photos uploaded to Tumblr"
msgstr "Tumblr қызметіне жүктеп салынған суреттер үшін әдепкі өлшемді білдіретін сандық код"

#: data/gsettings/org.gnome.shotwell-extras.gschema.xml:30
msgid "default blog"
msgstr "үнсіз келісім блогы"

#: data/gsettings/org.gnome.shotwell-extras.gschema.xml:31
msgid "The name of the default blog of the user, if any"
msgstr "Егер болса, пайдаланушының әдепкі блогының аты"

#: data/gsettings/org.gnome.shotwell.gschema.xml:22
msgid "display basic properties"
msgstr "негізгі қасиеттерді көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:23
msgid "True if the basic properties pane is to be displayed, false otherwise"
msgstr "Егер негізгі қасиеттер панелі көрсетілуі тиіс болса ақиқат, әйтпесе жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:28
msgid "display extended properties"
msgstr "кеңейтілген ақпаратты көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:29
msgid "True if the extended properties window is to be displayed, false otherwise"
msgstr "Егер кеңейтілген қасиеттер терезесі көрсетілуі тиіс болса ақиқат, әйтпесе жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:34
msgid "display sidebar"
msgstr "бүйір панелін көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:35
msgid "True if the sidebar is to be displayed, false otherwise"
msgstr "Егер бүйірлік панель көрсетілуі тиіс болса ақиқат, әйтпесе жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:40
msgid "display toolbar"
msgstr "саймандар панелін көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:41
msgid "True if the bottom toolbar is to be displayed, false otherwise"
msgstr "Егер төменгі саймандар панелі көрсетілуі тиіс болса ақиқат, әйтпесе жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:46
msgid "display map widget"
msgstr "карта виджетін көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:47
msgid "True if the map widget is to be displayed, false otherwise"
msgstr "Егер карта виджеті көрсетілуі тиіс болса ақиқат, әйтпесе жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:52
msgid "display search bar"
msgstr "іздеу өрісін көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:53
msgid "True if the Search/Filter Toolbar is to be displayed, false otherwise"
msgstr "Егер іздеу/сүзгі саймандар панелі көрсетілуі тиіс болса ақиқат, әйтпесе жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:58
msgid "display photo titles"
msgstr "фото атауларын көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:59
msgid "True if photo titles are to be displayed beneath thumbnails in collection views, false otherwise"
msgstr "Егер жиынтық көріністерінде сурет атаулары нобайлар астында көрсетілуі тиіс болса ақиқат, әйтпесе жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:64
msgid "display photo comments"
msgstr "фото түсіндірмелерін көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:65
msgid "True if photo comments are to be displayed beneath thumbnails in collection views, false otherwise"
msgstr "Егер жиынтық көріністерінде сурет пікірлері нобайлар астында көрсетілуі тиіс болса ақиқат, әйтпесе жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:70
msgid "display event comments"
msgstr "оқиға түсіндірмелерін көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:71
msgid "True if event comments are to be displayed beneath thumbnails in event views, false otherwise"
msgstr "Егер оқиға көріністерінде оқиға пікірлері нобайлар астында көрсетілуі тиіс болса ақиқат, әйтпесе жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:76
msgid "display photo tags"
msgstr "фото тегтерін көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:77
msgid "True if photo tags are to be listed beneath thumbnails in collection views, false otherwise"
msgstr "Егер жиынтық көріністерінде сурет тегтері нобайлар астында тізілуі тиіс болса ақиқат, әйтпесе жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:82
msgid "display photo ratings"
msgstr "фото рейтингтерін көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:83
msgid "True if a photo’s rating should be displayed as overlaid trinket, false otherwise"
msgstr "Егер суреттің рейтингі үстіне қойылған белгі ретінде көрсетілуі тиіс болса ақиқат, әйтпесе жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:88
msgid "rating filter level"
msgstr "рейтинг сүзгісінің деңгейі"

#: data/gsettings/org.gnome.shotwell.gschema.xml:89
msgid "Determines how to filter photos based on their ratings. 1: Rejected or better, 2: Unrated or better, 3: One or better, 4: Two or better, 5: Three or better, 6: Four or better, 7: Five or better"
msgstr "Суреттерді олардың рейтингіне қарай қалай сүзуді анықтайды. 1: Қабылданбаған немесе жақсырақ, 2: Рейтингсіз немесе жақсырақ, 3: Бір немесе жақсырақ, 4: Екі немесе жақсырақ, 5: Үш немесе жақсырақ, 6: Төрт немесе жақсырақ, 7: Бес немесе жақсырақ"

#: data/gsettings/org.gnome.shotwell.gschema.xml:94
msgid "sort events ascending"
msgstr "оқиғаларды өсу ретімен сұрыптау"

#: data/gsettings/org.gnome.shotwell.gschema.xml:95
msgid "True if events should be sorted ascending, false if descending"
msgstr "Егер оқиғалар өсу ретімен сұрыпталуы тиіс болса ақиқат, кему ретімен болса жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:100
msgid "sort library photos ascending"
msgstr "жинақ фотоларын өсу ретімен сұрыптау"

#: data/gsettings/org.gnome.shotwell.gschema.xml:101
msgid "True if library photos should be sorted ascending, false if descending"
msgstr "Егер кітапхана суреттері өсу ретімен сұрыпталуы тиіс болса ақиқат, кему ретімен болса жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:106
msgid "sort library photos criteria"
msgstr "кітапхана суреттерін сұрыптау критерийлері"

#: data/gsettings/org.gnome.shotwell.gschema.xml:107
msgid "A numeric code that specifies the sort criteria for photos in library views"
msgstr "Кітапхана көріністеріндегі суреттер үшін сұрыптау критерийлерін көрсететін сандық код"

#: data/gsettings/org.gnome.shotwell.gschema.xml:112
msgid "sort event photos ascending"
msgstr "оқиға фотоларын өсу ретімен сұрыптау"

#: data/gsettings/org.gnome.shotwell.gschema.xml:113
msgid "True if event photos should be sorted ascending, false if descending"
msgstr "Егер оқиға суреттері өсу ретімен сұрыпталуы тиіс болса ақиқат, кему ретімен болса жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:118
msgid "sort event photos criteria"
msgstr "оқиға фотоларын сұрыптау шарты"

#: data/gsettings/org.gnome.shotwell.gschema.xml:119
msgid "Specifies the sort criteria for event photos"
msgstr "Оқиға суреттері үшін сұрыптау критерийлерін көрсетеді"

#: data/gsettings/org.gnome.shotwell.gschema.xml:124
msgid "use 24 hour time"
msgstr "24-сағаттық уақытты қолдану"

#: data/gsettings/org.gnome.shotwell.gschema.xml:125
msgid "True if should display times with a 24 hour clock, false if times should use AM/PM notation"
msgstr "Егер уақыт 24 сағаттық форматта көрсетілуі тиіс болса ақиқат, AM/PM белгілеуі қолданылуы тиіс болса жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:130
msgid "keep relative time between photos"
msgstr "суреттер арасындағы салыстырмалы уақытты сақтау"

#: data/gsettings/org.gnome.shotwell.gschema.xml:131
msgid "True if when adjusting time/date of photos, relative time should be maintained. False if all photos should be set to the same time"
msgstr "Егер суреттердің уақытын/күнін түзету кезінде салыстырмалы уақыт сақталуы тиіс болса ақиқат. Егер барлық суреттер үшін бірдей уақыт орнатылуы тиіс болса жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:136
msgid "modify original photo files"
msgstr "түпнұсқа фотосурет файлдарын түзету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:137
msgid "True if when adjusting time/date of photos, the original files should be modified as well. False if changes are made only in the database"
msgstr "Егер суреттердің уақытын/күнін түзету кезінде түпнұсқа файлдар да өзгертілуі тиіс болса ақиқат. Егер өзгерістер тек дерекқорда жасалса жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:142
msgid "show welcome dialog on startup"
msgstr "іске қосылғанда сәлемдесу сұхбат терезесін көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:143
msgid "True if, when on startup, a welcome dialog should be shown. False if it should not be shown"
msgstr "Егер іске қосылғанда сәлемдесу сұхбат терезесі көрсетілуі тиіс болса ақиқат. Көрсетілмеуі тиіс болса жалған"

#: data/gsettings/org.gnome.shotwell.gschema.xml:148
msgid "sidebar position"
msgstr "бүйір панельдің орналасуы"

#: data/gsettings/org.gnome.shotwell.gschema.xml:149
msgid "The width, in pixels, of the sidebar"
msgstr "Бүйірлік панельдің ені, пиксельмен"

#: data/gsettings/org.gnome.shotwell.gschema.xml:154
msgid "photo thumbnail scale"
msgstr "сурет нобайының масштабы"

#: data/gsettings/org.gnome.shotwell.gschema.xml:155
msgid "The scale of photo thumbnails, ranging from 72 to 360"
msgstr "72-ден 360-қа дейінгі сурет нобайларының масштабы"

#: data/gsettings/org.gnome.shotwell.gschema.xml:160
msgid "pin toolbar state"
msgstr "саймандар панелінің бекіту күйі"

#: data/gsettings/org.gnome.shotwell.gschema.xml:161
msgid "Pin toolbar in fullscreen, or not"
msgstr "Саймандар панелін толық экранда бекіту немесе бекітпеу"

#: data/gsettings/org.gnome.shotwell.gschema.xml:166
msgid "prefer GTK+’s dark theme"
msgstr "GTK+ қараңғы тақырыбына басымдық беру"

#: data/gsettings/org.gnome.shotwell.gschema.xml:167
msgid "Whether to use the dark theme of GTK+ for Shotwell or not"
msgstr "Shotwell үшін GTK+ қараңғы тақырыбын қолдану-қолданбау"

#: data/gsettings/org.gnome.shotwell.gschema.xml:172
msgid "background for transparent images"
msgstr "мөлдір суреттерге арналған фон"

#: data/gsettings/org.gnome.shotwell.gschema.xml:173
msgid "The background to use for transparent images"
msgstr "Мөлдір суреттер үшін қолданылатын фон"

#: data/gsettings/org.gnome.shotwell.gschema.xml:178
msgid "color for solid transparency background"
msgstr "біртұтас мөлдір фон түсі"

#: data/gsettings/org.gnome.shotwell.gschema.xml:179
msgid "Color to use if background for transparent images is set to solid color"
msgstr "Егер мөлдір суреттер фоны біртұтас түс ретінде орнатылса, қолданылатын түс"

#: data/gsettings/org.gnome.shotwell.gschema.xml:184
msgid "Selection state of “hide photos” option"
msgstr "«суреттерді жасыру» опциясының таңдау күйі"

#: data/gsettings/org.gnome.shotwell.gschema.xml:185
msgid "Last used selection state of the “hide photos already imported” option in the import page"
msgstr "Импорттау бетіндегі «импортталған суреттерді жасыру» опциясының соңғы қолданылған таңдау күйі"

#: data/gsettings/org.gnome.shotwell.gschema.xml:192
msgid "duration"
msgstr "ұзақтығы"

#: data/gsettings/org.gnome.shotwell.gschema.xml:193
msgid "The time (in seconds) to show each photo in the slideshow"
msgstr "Слайдшоуда әр суретті көрсету уақыты (секундпен)"

#: data/gsettings/org.gnome.shotwell.gschema.xml:198
msgid "transition duration"
msgstr "ауысу ұзақтығы"

#: data/gsettings/org.gnome.shotwell.gschema.xml:199
msgid "The time (in seconds) that a transition runs between photos in a slideshow"
msgstr "Слайдшоуда суреттер арасындағы ауысудың орындалу уақыты (секундпен)"

#: data/gsettings/org.gnome.shotwell.gschema.xml:204
msgid "transition effect id"
msgstr "алмасу эффект id-і"

#: data/gsettings/org.gnome.shotwell.gschema.xml:205
msgid "The time (in seconds) to show each transition between photos in a slideshow"
msgstr "Слайдшоуда суреттер арасындағы әр ауысуды көрсету уақыты (секундпен)"

#: data/gsettings/org.gnome.shotwell.gschema.xml:210
msgid "Show title"
msgstr "Атауын көрсету"

#: data/gsettings/org.gnome.shotwell.gschema.xml:211
msgid "Whether to show the title of a photo during the slideshow"
msgstr "Слайдшоу кезінде фотосурет атауын көрсету керек пе"

#: data/gsettings/org.gnome.shotwell.gschema.xml:216 data/ui/slideshow_settings.ui:154
msgid "Shuffle"
msgstr "Араластыру"

#: data/gsettings/org.gnome.shotwell.gschema.xml:217
msgid "Whether to shuffle the order of photos during the slideshow"
msgstr "Слайдшоу кезінде фотосуреттер ретін араластыру керек пе"

#: data/gsettings/org.gnome.shotwell.gschema.xml:224
msgid "maximize library window"
msgstr "кітапхана терезесін жаю"

#: data/gsettings/org.gnome.shotwell.gschema.xml:225
msgid "True if library application is maximized, false otherwise"
msgstr "Егер кітапхана қолданбасы жайылған болса True, әйтпесе false"

#: data/gsettings/org.gnome.shotwell.gschema.xml:230
msgid "width of library window"
msgstr "кітапхана терезесінің ені"

#: data/gsettings/org.gnome.shotwell.gschema.xml:231
msgid "The last recorded width of the library application window"
msgstr "Кітапхана қолданбасы терезесінің соңғы жазылған ені"

#: data/gsettings/org.gnome.shotwell.gschema.xml:236
msgid "height of library window"
msgstr "кітапхана терезесінің биіктігі"

#: data/gsettings/org.gnome.shotwell.gschema.xml:237
msgid "The last recorded height of the library application window"
msgstr "Кітапхана қолданбасы терезесінің соңғы жазылған биіктігі"

#: data/gsettings/org.gnome.shotwell.gschema.xml:242
msgid "maximize direct-edit window"
msgstr "тікелей түзету терезесін жаю"

#: data/gsettings/org.gnome.shotwell.gschema.xml:243
msgid "True if direct-edit application is maximized, false otherwise"
msgstr "Егер тікелей түзету қолданбасы жайылған болса True, әйтпесе false"

#: data/gsettings/org.gnome.shotwell.gschema.xml:248
msgid "width of direct-edit window"
msgstr "тікелей түзету терезесінің ені"

#: data/gsettings/org.gnome.shotwell.gschema.xml:249
msgid "The last recorded width of the direct-edit application window"
msgstr "Тікелей түзету қолданбасы терезесінің соңғы жазылған ені"

#: data/gsettings/org.gnome.shotwell.gschema.xml:254
msgid "height of direct-edit window"
msgstr "тікелей түзету терезесінің биіктігі"

#: data/gsettings/org.gnome.shotwell.gschema.xml:255
msgid "The last recorded height of the direct-edit application window"
msgstr "Тікелей түзету қолданбасы терезесінің соңғы жазылған биіктігі"

#: data/gsettings/org.gnome.shotwell.gschema.xml:260
msgid "sidebar divider position"
msgstr "бүйірлік панель бөлгішінің орны"

#: data/gsettings/org.gnome.shotwell.gschema.xml:261
msgid "The last recorded position of the divider between the sidebar and view in library application window"
msgstr "Кітапхана қолданбасы терезесіндегі бүйірлік панель мен көрініс арасындағы бөлгіштің соңғы жазылған орны"

#: data/gsettings/org.gnome.shotwell.gschema.xml:268
msgid "import directory"
msgstr "буманы импорттау"

#: data/gsettings/org.gnome.shotwell.gschema.xml:269
msgid "Directory in which imported photo files are placed"
msgstr "Импортталған фотосурет файлдары орналасатын бума"

#: data/gsettings/org.gnome.shotwell.gschema.xml:274
msgid "watch library directory for new files"
msgstr "жинақ бумасын жаңа файлдарға бақылау"

